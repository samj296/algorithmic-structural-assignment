<!DOCTYPE html>
<html lang = "en">
    <head>
        <title> Mighty Husk - Login </title>
        <link rel="stylesheet" href = "/assets/CSS/style.css">
    </head>
    <body>
           
           <%- include("partials/header",{
                header: "L o a d i n g  D O O R  O S......",
                pTag: "Disk Operating Output Runtime"
            }) %>
        
        <form action="/login" method = "POST" class = "login-form">
            <input id = "login-email" class = "input" type = "text" placeholder = "email" name = "name" required>
            <br>
            <input id = "login-password" class = "input" type = "password" placeholder = "Password">
            <br>
            <button id = "signin" class = "btn" type = "submit" data-action = "login">Login</button>
            <button id = "signup-btn" class = "btn" type = "button" data-action="sign-up">Sign Up</button>
            <button id = "reset" class = "btn" type = "reset" data-action = "reset">Reset</button>
        </form>
        <script type="module" src = "/script/terminalEngine.js"></script>
    </body>
</html>